{
  "name": "expo-tv-launcher-example",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "prebuild": "expo prebuild --clean",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-native": "npm:react-native-tvos@0.81-stable"
  },
  "devDependencies": {
    "@react-native-tvos/config-tv": "*",
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "react-native"
      ]
    },
    "autolinking": {
      "nativeModulesDir": ".."
    }
  }
}
